# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ===== LLM providers =====
# Generator model (Gemini 2.5 Flash) — used by all three paradigms.
# Gemini quotas are per-GCP-project, not per-key, so the three paradigms
# can be bound to *separate* projects to decouple their daily 10k/day
# Tier 1 caps. The fallback GOOGLE_API_KEY is used by anything not
# explicitly overridden (e.g. evaluation/judge.py uses Gemini 2.5 Pro,
# which has its own quota track on whichever project this key belongs to).
GOOGLE_API_KEY=

# Optional per-paradigm keys, each from its own GCP project. Each line
# below corresponds to a different GCP project — that's the requirement
# for independent quotas. If unset, the paradigm falls back to GOOGLE_API_KEY.
GOOGLE_API_KEY_RAG=
GOOGLE_API_KEY_AGENTIC=
GOOGLE_API_KEY_GRAPHRAG=

# Embedding model (text-embedding-3-small) — used by RAG and GraphRAG
# for indexing. No paradigm-scoped variant; OpenAI quotas are higher
# and not the typical bottleneck.
OPENAI_API_KEY=

# ===== Observability =====
# LangSmith tracing — enables full-pipeline traces for all three graphs.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=qa-paradigm-lab
LANGSMITH_TRACING=true

# ===== Optional / paradigm-specific =====
# Knowledge graph storage (used by GraphRAG). Leave empty to use local SQLite.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
