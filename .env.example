# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ===== LLM providers =====
# Generator model (Gemini Flash Lite) — used by all three paradigms.
GOOGLE_API_KEY=

# Embedding model (text-embedding-3-small) — used by RAG and GraphRAG.
OPENAI_API_KEY=

# ===== Observability =====
# LangSmith tracing — enables full-pipeline traces for all three graphs.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=qa-paradigm-lab
LANGSMITH_TRACING=true

# ===== Optional / paradigm-specific =====
# Knowledge graph storage (used by GraphRAG). Leave empty to use local SQLite.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
